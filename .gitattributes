# Auto detect text files and perform LF normalization
* text=auto

# Source code - always use LF in repository, auto-convert on checkout
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.sql text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.jsp text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts must use LF (even on Windows)
*.sh text eol=lf

# Windows scripts must use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Documentation - allow either, stored as-is
*.md text
*.txt text
*.adoc text

# Binary files
*.jar binary
*.war binary
*.ear binary
*.zip binary
*.tar binary
*.gz binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.class binary
